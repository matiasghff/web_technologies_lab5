<div class="mb-4">
  <h1 class="h2 mb-1">Vets</h1>
  <p class="text-muted mb-0">Meet the clinic veterinarians.</p>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Specialization</th>
          </tr>
        </thead>
        <tbody>
          <% @vets.each do |vet| %>
            <tr>
              <td>
                <%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet), class: "fw-semibold text-decoration-none" %>
              </td>
              <td><%= vet.email %></td>
              <td><span class="badge bg-info-subtle text-info"><%= vet.specialization %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>