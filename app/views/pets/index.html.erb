<div class="mb-4">
  <h1 class="h2 mb-1">Pets</h1>
  <p class="text-muted mb-0">Browse pets and their owners.</p>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Species</th>
            <th>Breed</th>
            <th>Owner</th>
            <th>Date of Birth</th>
          </tr>
        </thead>
        <tbody>
          <% @pets.each do |pet| %>
            <tr>
              <td>
                <%= link_to pet.name, pet_path(pet), class: "fw-semibold text-decoration-none" %>
              </td>
              <td><span class="badge bg-secondary-subtle text-secondary"><%= pet.species.capitalize %></span></td>
              <td><%= pet.breed %></td>
              <td>
                <%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner), class: "text-decoration-none" %>
              </td>
              <td><%= format_date(pet.date_of_birth) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>