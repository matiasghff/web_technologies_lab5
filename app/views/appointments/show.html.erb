<h1 class="mb-4">Appointment Details</h1>

<div class="card mb-4">
  <div class="card-body">
    <p><strong>Date:</strong> <%= format_datetime(@appointment.date) %></p>
    <p><strong>Reason:</strong> <%= @appointment.reason %></p>
    <p><strong>Status:</strong> <%= human_status(@appointment.status) %></p>
    <p>
      <strong>Pet:</strong>
      <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %>
    </p>
    <p>
      <strong>Vet:</strong>
      <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", vet_path(@appointment.vet) %>
    </p>
  </div>
</div>

<h2>Treatments</h2>

<% if @appointment.treatments.any? %>
  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Administered At</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @appointment.treatments.each do |treatment| %>
        <tr>
          <td><%= treatment.name %></td>
          <td><%= treatment.medication %></td>
          <td><%= treatment.dosage %></td>
          <td><%= format_datetime(treatment.administered_at) %></td>
          <td><%= treatment.notes %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No treatments for this appointment.</p>
<% end %>