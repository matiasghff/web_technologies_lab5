<div class="mb-4">
  <h1 class="h2 mb-1">Appointments</h1>
  <p class="text-muted mb-0">Review all scheduled and past appointments.</p>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Pet</th>
            <th>Vet</th>
            <th>Reason</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @appointments.each do |appointment| %>
            <tr>
              <td>
                <%= link_to format_datetime(appointment.date), appointment_path(appointment), class: "fw-semibold text-decoration-none" %>
              </td>
              <td><%= appointment.pet.name %></td>
              <td><%= "#{appointment.vet.first_name} #{appointment.vet.last_name}" %></td>
              <td><%= appointment.reason %></td>
              <td>
                <% badge_class =
                  case appointment.status
                  when "scheduled" then "bg-primary-subtle text-primary"
                  when "in_progress" then "bg-warning-subtle text-warning"
                  when "completed" then "bg-success-subtle text-success"
                  when "cancelled" then "bg-danger-subtle text-danger"
                  end %>

                <span class="badge <%= badge_class %>">
                  <%= human_status(appointment.status) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>