<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h2 mb-1">Owners</h1>
    <p class="text-muted mb-0">Manage and review all pet owners.</p>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Pets</th>
          </tr>
        </thead>
        <tbody>
          <% @owners.each do |owner| %>
            <tr>
              <td>
                <%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner), class: "fw-semibold text-decoration-none" %>
              </td>
              <td><%= owner.email %></td>
              <td><%= owner.phone %></td>
              <td>
                <span class="badge bg-primary-subtle text-primary">
                  <%= owner.pets.size %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>